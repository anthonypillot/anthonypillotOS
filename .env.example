# PostgreSQL
#
# 1. Start a local PostgreSQL container:
#    docker run --name postgres \
#      -e POSTGRES_USER=anthonypillot \
#      -e POSTGRES_PASSWORD=password \
#      -e POSTGRES_DB=anthonypillotOS \
#      -v postgres-data:/var/lib/postgresql/data \
#      -p 5432:5432 \
#      -d postgres:16-alpine
#
# 2. Copy this file to .env and fill in POSTGRES_PRISMA_URL:
#    cp .env.example .env
#
# 3. Set up your database:
#    First-time setup:
#      npx prisma db push
#
#    Or for existing setups:
#      npx prisma migrate dev
POSTGRES_PRISMA_URL="postgres://anthonypillot:password@localhost:5432/anthonypillotOS"
